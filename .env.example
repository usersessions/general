# ---- Phase 1 (required) ----
# Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the browser. Not used in Phase 1 yet,
# but will be needed for privileged server operations in later phases.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Phase 3 ----
RESEND_API_KEY=
EMAIL_FROM="I&S General Supplies <billing@yourdomain.co.ke>"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Phase 4: M-Pesa Daraja ----
MPESA_ENV=sandbox            # sandbox | production
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=

# ---- Phase 6: KRA eTIMS (OSCU, sandbox first) ----
ETIMS_API_URL=               # sandbox base URL from KRA onboarding
ETIMS_TIN=
ETIMS_BRANCH_ID=00
ETIMS_CMC_KEY=
CRON_SECRET=                 # protects /api/etims/process
